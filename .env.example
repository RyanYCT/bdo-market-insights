# AWS Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# AWS Account Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# AWS Credentials (Alternative 1: Use environment variables)
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Note: It's recommended to use AWS CLI profiles instead of hardcoding credentials
# Run: aws configure --profile bdo-staging
# Then use: export AWS_PROFILE=bdo-staging

# Deployment Configuration
ENVIRONMENT=staging

# API Gateway Configuration
ALLOWED_CORS_ORIGINS=https://staging.example.com,https://staging-app.example.com

# Lambda Configuration
LAMBDA_TIMEOUT=300
LAMBDA_MEMORY_SIZE=512

# Database Configuration (stored in AWS Secrets Manager)
# These are just identifiers, actual credentials are in Secrets Manager
DB_SECRET_NAME=bdo-db-credentials-staging
EXTERNAL_API_SECRET_NAME=bdo-external-api-staging

# EventBridge Scheduler Configuration
ETL_SCHEDULE_EXPRESSION=cron(0 2 * * ? *)
RETENTION_SCHEDULE_EXPRESSION=cron(0 3 1 * ? *)

# Monitoring Configuration
ALARM_EMAIL=devops@example.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional: S3 Bucket for Deployment Artifacts
DEPLOYMENT_BUCKET=bdo-deployments-staging

# Optional: VPC Configuration (if Lambda needs VPC access)
# VPC_SUBNET_IDS=subnet-12345,subnet-67890
# VPC_SECURITY_GROUP_IDS=sg-12345

# Optional: Tags for AWS Resources
PROJECT_NAME=bdo-market-insights
COST_CENTER=engineering
OWNER=devops-team
