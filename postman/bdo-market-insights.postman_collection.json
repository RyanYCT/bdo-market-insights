              "variable": [
                {
                  "key": "item_id",
                  "value": "",
                  "description": "Path parameter (e.g. a tracked item id; see GET /v1/items)."
                }
              ],
              "query": [
                {
                  "key": "region",
                  "value": "tw",
                  "description": "BDO server region. Accepted: na, eu, sea, mena, kr, ru, jp, th, tw, sa, console_eu, console_na, console_asia. Default: tw.",
                  "disabled": true
                },
                {
                  "key": "sid",
                  "value": "",
                  "description": "Enhancement sub-id. Default: 0 (the base item).",
                  "disabled": true
                },
                {
                  "key": "window_days",
                  "value": "14",
                  "description": "Trailing analytics window in days. Range: 1-90. Default: 14. Needs at least 7 daily points.",
                  "disabled": true
