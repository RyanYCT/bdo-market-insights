          "name": "GET /v1/market/items/{item_id}/analysis",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/market/items/:item_id/analysis?region=tw&sid=&window_days=14",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "market",
                "items",
                ":item_id",
                "analysis"
